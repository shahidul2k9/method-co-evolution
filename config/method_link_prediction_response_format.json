{
  "type": "json_schema",
  "name": "method_link_prediction",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "methods": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "confidence": {
              "type": "number"
            },
            "rationale": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "confidence",
            "rationale"
          ]
        }
      },
      "overall_rationale": {
        "type": "string"
      }
    },
    "required": [
      "methods",
      "overall_rationale"
    ]
  }
}
